# ── Base PUBLIQUE (mesures du capteur) ───────────────────────────────
# Windows + XAMPP : MySQL/MariaDB écoute sur le port 3306.
#   (Apache XAMPP : 8080 / 443 — non utilisé par le backend Node.)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=capteur_distance
DB_USER=root
DB_PASSWORD=
# macOS + MAMP (config d'origine du projet) : décommenter et commenter le bloc ci-dessus.
# DB_PORT=8889
# DB_PASSWORD=root

# ── Base PRIVÉE (utilisateurs + scores) ──────────────────────────────
DB_PRIVATE_HOST=127.0.0.1
DB_PRIVATE_PORT=3306
DB_PRIVATE_NAME=capteur_private
DB_PRIVATE_USER=root
DB_PRIVATE_PASSWORD=
# macOS + MAMP : DB_PRIVATE_PORT=8889 / DB_PRIVATE_PASSWORD=root

# ── Auth ─────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_SECRET
JWT_EXPIRES_IN=7d

# ── Serveur ───────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# DEMO_MODE=true  → /latest renvoie des valeurs simulées (capteur non branché)
# DEMO_MODE=false → on lit les vraies mesures insérées par le bridge Python
DEMO_MODE=false
